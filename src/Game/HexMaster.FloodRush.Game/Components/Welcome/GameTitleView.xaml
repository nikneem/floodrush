<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HexMaster.FloodRush.Game.Components.Welcome.GameTitleView">

    <VerticalStackLayout Spacing="10" HorizontalOptions="Start">

        <!-- Title with layered glow effect -->
        <Grid x:Name="TitleGrid" HorizontalOptions="Start">

            <!-- Outer glow halo — large soft radius, low opacity -->
            <Label x:Name="GlowOuter"
                   Text="FloodRush"
                   Style="{StaticResource GameTitleStyle}"
                   Opacity="0.25">
                <Label.Shadow>
                    <Shadow Brush="{StaticResource BrandAmber}"
                            Offset="0,0"
                            Radius="48"
                            Opacity="1.0"/>
                </Label.Shadow>
            </Label>

            <!-- Mid glow — medium radius -->
            <Label x:Name="GlowMid"
                   Text="FloodRush"
                   Style="{StaticResource GameTitleStyle}"
                   Opacity="0.45">
                <Label.Shadow>
                    <Shadow Brush="{StaticResource BrandAmberLight}"
                            Offset="0,0"
                            Radius="24"
                            Opacity="1.0"/>
                </Label.Shadow>
            </Label>

            <!-- Crisp foreground title -->
            <Label Text="FloodRush"
                   Style="{StaticResource GameTitleStyle}">
                <Label.Shadow>
                    <Shadow Brush="{StaticResource BrandAmberLight}"
                            Offset="0,0"
                            Radius="8"
                            Opacity="0.9"/>
                </Label.Shadow>
            </Label>
        </Grid>

        <!-- Tagline -->
        <Label Text="Place pipes. Redirect the flood."
               Style="{StaticResource PageSubtitleStyle}"
               HorizontalOptions="Start"/>

        <!-- Amber accent rule -->
        <BoxView x:Name="AccentRule"
                 HeightRequest="2"
                 WidthRequest="220"
                 HorizontalOptions="Start"
                 Margin="0,4,0,0">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource BrandAmber}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

    </VerticalStackLayout>
</ContentView>
