<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HexMaster.FloodRush.Game.Views.LevelFailedOverlay">
    <Grid>
        <!-- Full-bleed failure visual -->
        <Image Source="level_failed_visual.png"
               Aspect="AspectFill"
               Opacity="0.92"/>
        <!-- Subtle dark veil so the card stays readable -->
        <BoxView Color="{StaticResource AppBackground}" Opacity="0.45"/>

        <!-- Centred failure card -->
        <Border Style="{StaticResource GameCardStyle}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MinimumWidthRequest="360"
                MaximumWidthRequest="520">
            <VerticalStackLayout Spacing="20" Padding="8">

                <!-- Sad icon — leaking fluid -->
                <Label Text="💧"
                       FontSize="64"
                       HorizontalTextAlignment="Center"/>

                <!-- Heading -->
                <Label Text="Flow Leaked!"
                       Style="{StaticResource PageTitleStyle}"
                       TextColor="{StaticResource Danger}"
                       HorizontalTextAlignment="Center"/>

                <!-- Explanation -->
                <Label Text="The fluid ran out of pipe and spilled!"
                       Style="{StaticResource PageSubtitleStyle}"
                       HorizontalTextAlignment="Center"/>

                <!-- Points earned this run (not submitted to server) -->
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="Points this run"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalTextAlignment="Center"/>
                    <Label HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Score}"
                                      FontFamily="Peralta"
                                      FontSize="48"
                                      TextColor="{StaticResource TextSecondary}"/>
                                <Span Text=" pts"
                                      FontFamily="PatrickHand"
                                      FontSize="22"
                                      TextColor="{StaticResource TextMuted}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>

                <!-- Actions -->
                <Button Text="Try Again"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RetryCommand}"
                        HorizontalOptions="Fill"/>
                <Button Text="Quit to Menu"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding QuitCommand}"
                        HorizontalOptions="Fill"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
