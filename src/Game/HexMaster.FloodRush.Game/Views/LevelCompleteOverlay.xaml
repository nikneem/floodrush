<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HexMaster.FloodRush.Game.Views.LevelCompleteOverlay">
    <Grid>
        <!-- Full-bleed celebration visual -->
        <Image Source="level_completed_visual.png"
               Aspect="AspectFill"
               Opacity="0.92"/>
        <!-- Subtle dark veil so the card stays readable -->
        <BoxView Color="{StaticResource AppBackground}" Opacity="0.45"/>

        <!-- Centred celebration card -->
        <Border Style="{StaticResource GameCardStyle}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MinimumWidthRequest="360"
                MaximumWidthRequest="520">
            <VerticalStackLayout Spacing="20" Padding="8">

                <!-- Trophy icon -->
                <Label Text="🏆"
                       FontSize="64"
                       HorizontalTextAlignment="Center"/>

                <!-- Heading -->
                <Label Text="Level Complete!"
                       Style="{StaticResource PageTitleStyle}"
                       TextColor="{StaticResource Success}"
                       HorizontalTextAlignment="Center"/>

                <!-- Score earned -->
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="You scored"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalTextAlignment="Center"/>
                    <Label HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Score}"
                                      FontFamily="Peralta"
                                      FontSize="48"
                                      TextColor="{StaticResource BrandAmber}"/>
                                <Span Text=" pts"
                                      FontFamily="PatrickHand"
                                      FontSize="22"
                                      TextColor="{StaticResource TextSecondary}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>

                <!-- Score-submission indicator -->
                <StackLayout Orientation="Horizontal"
                             HorizontalOptions="Center"
                             Spacing="8"
                             IsVisible="{Binding IsScoreSubmitting}">
                    <ActivityIndicator IsRunning="{Binding IsScoreSubmitting}"
                                       Color="{StaticResource BrandAmber}"
                                       WidthRequest="18"
                                       HeightRequest="18"/>
                    <Label Text="Saving score to server…"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalOptions="Center"/>
                </StackLayout>

                <!-- Highscores -->
                <Grid ColumnDefinitions="*,1,*"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="16"
                      RowSpacing="4">

                    <!-- Divider -->
                    <BoxView Grid.Row="0" Grid.ColumnSpan="3"
                             Color="{StaticResource SurfaceSecondary}"
                             HeightRequest="1"
                             Margin="0,4"/>

                    <!-- Column headers -->
                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Your best"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalTextAlignment="Center"/>
                    <BoxView Grid.Row="1" Grid.Column="1"
                             Color="{StaticResource SurfaceSecondary}"
                             WidthRequest="1"/>
                    <Label Grid.Row="1" Grid.Column="2"
                           Text="Global best"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalTextAlignment="Center"/>

                    <!-- Values -->
                    <Label Grid.Row="2" Grid.Column="0"
                           Text="{Binding PlayerHighScore, StringFormat='{0:N0} pts', TargetNullValue='—'}"
                           FontFamily="PatrickHand"
                           FontSize="22"
                           TextColor="{StaticResource BrandAmber}"
                           HorizontalTextAlignment="Center"/>
                    <BoxView Grid.Row="2" Grid.Column="1"
                             Color="{StaticResource SurfaceSecondary}"
                             WidthRequest="1"/>
                    <Label Grid.Row="2" Grid.Column="2"
                           Text="{Binding GlobalHighScore, StringFormat='{0:N0} pts', TargetNullValue='—'}"
                           FontFamily="PatrickHand"
                           FontSize="22"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalTextAlignment="Center"/>

                </Grid>

                <!-- Actions -->
                <Button Text="Next Level"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NextLevelCommand}"
                        HorizontalOptions="Fill"/>
                <Button Text="Quit to Menu"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding QuitCommand}"
                        HorizontalOptions="Fill"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
