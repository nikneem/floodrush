<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HexMaster.FloodRush.Game.Controls.ZoomablePlayfieldViewport"
             x:Name="ViewportRoot">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="8">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12">
            <Border Style="{StaticResource StatusBadgeStyle}">
                <Label x:Name="ZoomBadgeLabel"
                       Style="{StaticResource MutedTextStyle}"
                       VerticalOptions="Center"/>
            </Border>

            <Label Grid.Column="1"
                   Text="Pinch to zoom and drag to pan across the playfield."
                   Style="{StaticResource MutedTextStyle}"
                   VerticalOptions="Center"/>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource GameCardStyle}"
                Padding="0">
            <ScrollView x:Name="PlayfieldScrollView"
                        Orientation="Both">
                <Grid x:Name="ScaledContentHost"
                      WidthRequest="{Binding Source={x:Reference ViewportRoot}, Path=ScaledContentWidth}"
                      HeightRequest="{Binding Source={x:Reference ViewportRoot}, Path=ScaledContentHeight}">
                    <Grid.GestureRecognizers>
                        <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
                    </Grid.GestureRecognizers>

                    <ContentPresenter Content="{Binding Source={x:Reference ViewportRoot}, Path=PlayfieldContent}"
                                      HorizontalOptions="Fill"
                                      VerticalOptions="Fill" />
                </Grid>
            </ScrollView>
        </Border>
    </Grid>
</ContentView>
