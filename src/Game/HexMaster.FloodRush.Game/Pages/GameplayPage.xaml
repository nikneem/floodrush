<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:HexMaster.FloodRush.Game.Controls"
             xmlns:vm="clr-namespace:HexMaster.FloodRush.Game.ViewModels"
             xmlns:views="clr-namespace:HexMaster.FloodRush.Game.Views"
             x:Class="HexMaster.FloodRush.Game.Pages.GameplayPage"
             Shell.NavBarIsVisible="False">
    <ContentPage.Background>
        <SolidColorBrush Color="{StaticResource AppBackground}"/>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">
        <!-- HUD header row -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBackgroundBrush}"
                Padding="16,8">
             <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                 <Label Grid.Column="0"
                       Text="{Binding LevelDisplayName}"
                       Style="{StaticResource SectionHeadingStyle}"
                       FontSize="16"
                       VerticalOptions="Center"/>

                <StackLayout Grid.Column="1" Orientation="Horizontal" Spacing="4"
                             VerticalOptions="Center" Margin="0,0,24,0">
                    <Label Text="Prep: " Style="{StaticResource MutedTextStyle}" FontSize="14"/>
                    <Label Text="{Binding RemainingPrepSeconds, StringFormat='{0}s'}"
                           TextColor="{StaticResource BrandAmber}"
                           FontAttributes="Bold"
                           FontSize="14"/>
                </StackLayout>

                 <StackLayout Grid.Column="2" Orientation="Horizontal" Spacing="4"
                              VerticalOptions="Center" Margin="0,0,24,0">
                    <Label Text="Flow speed: " Style="{StaticResource MutedTextStyle}" FontSize="14"/>
                    <Label Text="{Binding FlowSpeedIndicator}"
                            TextColor="{StaticResource BrandAmber}"
                            FontAttributes="Bold"
                            FontSize="14"/>
                </StackLayout>

                <Button Grid.Column="3"
                        Text="⏸"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        FontSize="18"
                        Command="{Binding PauseCommand}"/>
            </Grid>
        </Border>

        <!-- Game board area -->
        <Grid Grid.Row="1">
            <Grid ColumnDefinitions="220,*"
                  ColumnSpacing="8">
                <Border Grid.Column="0"
                        Margin="16,16,8,16"
                        Padding="14"
                        Background="{StaticResource SurfaceBackgroundBrush}"
                        Stroke="{StaticResource CardBackgroundBrush}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">
                    <Grid RowDefinitions="Auto,Auto,*"
                          RowSpacing="12">
                        <Label Grid.Row="0"
                               Text="Pipe stack"
                               Style="{StaticResource SectionHeadingStyle}"
                               HorizontalTextAlignment="Center"/>

                        <Label Grid.Row="1"
                               Text="The bottom tile places next."
                               Style="{StaticResource MutedTextStyle}"
                               HorizontalTextAlignment="Center"/>

                        <VerticalStackLayout x:Name="PipeStackContainer"
                                             Grid.Row="2"
                                             BindableLayout.ItemsSource="{Binding UpcomingPipes}"
                                             Spacing="10"
                                             VerticalOptions="End">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:PipeStackItem">
                                    <Border Padding="10"
                                            Background="{StaticResource SurfaceBackgroundBrush}"
                                            Stroke="{StaticResource CardBackgroundBrush}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 14"
                                            Opacity="{Binding PreviewOpacity}">
                                        <Grid ColumnDefinitions="64,*"
                                              ColumnSpacing="10"
                                              MinimumHeightRequest="76">
                                            <Border Background="{StaticResource AppBackgroundGradientBrush}"
                                                    Stroke="{StaticResource SecondaryBrush}"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 12">
                                                <Label Text="{Binding Glyph}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       FontSize="30"
                                                       TextColor="{StaticResource BrandAmber}"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Label}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       FontAttributes="Bold"/>
                                                <Label Text="{Binding QueueLabel}"
                                                       Style="{StaticResource MutedTextStyle}"/>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsNextToPlace}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="{StaticResource CardGradientBrush}"/>
                                                <Setter Property="Stroke"
                                                        Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="StrokeThickness"
                                                        Value="2"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <controls:ZoomablePlayfieldViewport Grid.Column="1"
                                                    Margin="8,16,16,16"
                                                    IsVisible="{Binding HasLevelLoaded}"
                                                    ContentWidth="{Binding BoardPixelWidth}"
                                                    ContentHeight="{Binding BoardPixelHeight}"
                                                    MinZoom="1"
                                                    MaxZoom="{Binding MaxTileZoom}">
                    <controls:ZoomablePlayfieldViewport.PlayfieldContent>
                        <controls:PlayfieldBoardView BoardWidth="{Binding BoardWidth}"
                                                     BoardHeight="{Binding BoardHeight}"
                                                     Tiles="{Binding BoardTiles}"
                                                     TileSize="{Binding TileRenderSize}"
                                                     TileSpacing="{Binding TileSpacing}" />
                    </controls:ZoomablePlayfieldViewport.PlayfieldContent>
                </controls:ZoomablePlayfieldViewport>
            </Grid>

            <Grid IsVisible="{Binding IsBusy}"
                  BackgroundColor="{StaticResource AppBackground}"
                  Opacity="0.88">
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource BrandAmber}"
                                       WidthRequest="56"
                                       HeightRequest="56"/>
                    <Label Text="Loading level from the server..."
                           Style="{StaticResource BodyTextStyle}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Grid>

            <Grid IsVisible="{Binding HasLoadError}">
                <Border Style="{StaticResource GameCardStyle}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        MaximumWidthRequest="560">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Level load failed"
                               Style="{StaticResource SectionHeadingStyle}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding LoadErrorMessage}"
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Pause overlay -->
            <views:PauseResultOverlay
                BindingContext="{Binding}"
                IsVisible="{Binding IsPaused}"/>
            <!-- Game over overlay -->
            <views:PauseResultOverlay
                BindingContext="{Binding}"
                IsVisible="{Binding IsGameOver}"/>

            <Grid IsVisible="{Binding IsPreStartModalVisible}">
                <BoxView Color="{StaticResource AppBackground}"
                         Opacity="0.82"/>

                <Border Style="{StaticResource GameCardStyle}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        MaximumWidthRequest="520">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="16">
                        <VerticalStackLayout Grid.Row="0"
                                             Spacing="6">
                            <Label Text="{Binding LevelNumberLabel}"
                                   Style="{StaticResource PageTitleStyle}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding DisplayName}"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="*,Auto">
                            <Label Text="Difficulty"
                                   Style="{StaticResource BodyTextStyle}"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Difficulty}"
                                   Style="{StaticResource HudValueStyle}"/>
                        </Grid>

                        <Grid Grid.Row="2"
                              ColumnDefinitions="*,Auto">
                            <Label Text="Flow timeout"
                                   Style="{StaticResource BodyTextStyle}"/>
                            <Label Grid.Column="1"
                                   Text="{Binding FlowTimeoutLabel}"
                                   Style="{StaticResource HudValueStyle}"/>
                        </Grid>

                        <Grid Grid.Row="3"
                              ColumnDefinitions="*,Auto">
                            <Label Text="Flow speed"
                                   Style="{StaticResource BodyTextStyle}"/>
                            <Label Grid.Column="1"
                                   Text="{Binding FlowSpeedIndicator}"
                                   Style="{StaticResource HudValueStyle}"/>
                        </Grid>

                        <Button Grid.Row="4"
                                Text="Start"
                                Command="{Binding StartLevelCommand}"
                                HorizontalOptions="Fill"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
