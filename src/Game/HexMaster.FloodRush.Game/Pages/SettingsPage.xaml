<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HexMaster.FloodRush.Game.ViewModels"
             x:Class="HexMaster.FloodRush.Game.Pages.SettingsPage"
             Shell.NavBarIsVisible="False">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0d1b2a" Offset="0"/>
            <GradientStop Color="#102035" Offset="1"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*" Padding="24,12">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
            <Button Grid.Column="0"
                    Text="← Back"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding BackCommand}"
                    Padding="16,8"
                    MinimumWidthRequest="0"/>
            <Label Grid.Column="1"
                   Text="Settings"
                   Style="{StaticResource SectionHeadingStyle}"
                   VerticalOptions="Center"
                   Margin="16,0"/>
        </Grid>

        <!-- Settings content — scrollable so it works on all landscape screen sizes -->
        <ScrollView Grid.Row="1">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <!-- Left column: Profile -->
                <Border Grid.Column="0" Style="{StaticResource GameCardStyle}"
                        VerticalOptions="Start" Padding="14">
                    <StackLayout Spacing="10">
                        <Label Text="Player Profile"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="Display Name" Style="{StaticResource MutedTextStyle}"/>
                        <Entry Text="{Binding PlayerName}"
                               Placeholder="Enter your name"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="{StaticResource SurfaceBackground}"
                               HeightRequest="40"/>
                        <Button Text="Save Name"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SavePlayerNameCommand}"
                                Padding="16,8"
                                FontSize="14"
                                MinimumWidthRequest="0"
                                HorizontalOptions="Start"/>
                    </StackLayout>
                </Border>

                <!-- Right column: Game settings + danger zone -->
                <StackLayout Grid.Column="1" Spacing="12">
                    <Border Style="{StaticResource GameCardStyle}" Padding="14">
                        <StackLayout Spacing="10">
                            <Label Text="Game Settings"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Sound Effects"
                                       FontSize="14" TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"/>
                                <Switch Grid.Column="1" IsToggled="{Binding SoundEnabled}"
                                        OnColor="{StaticResource BrandAmber}"
                                        ThumbColor="{StaticResource TextPrimary}"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Music"
                                       FontSize="14" TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"/>
                                <Switch Grid.Column="1" IsToggled="{Binding MusicEnabled}"
                                        OnColor="{StaticResource BrandAmber}"
                                        ThumbColor="{StaticResource TextPrimary}"/>
                            </Grid>
                        </StackLayout>
                    </Border>

                    <Border Style="{StaticResource GameCardStyle}" Padding="14">
                        <StackLayout Spacing="10">
                            <Label Text="Danger Zone"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource Danger}"/>
                            <Label Text="Erases all local progress. Cannot be undone."
                                   Style="{StaticResource MutedTextStyle}"/>
                            <Button Text="Reset Progress"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding ResetProgressCommand}"
                                    Padding="16,8"
                                    FontSize="14"
                                    MinimumWidthRequest="0"
                                    HorizontalOptions="Start"/>
                        </StackLayout>
                    </Border>
                </StackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
