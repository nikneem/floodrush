<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HexMaster.FloodRush.Game.ViewModels"
             xmlns:welcome="clr-namespace:HexMaster.FloodRush.Game.Components.Welcome"
             x:Class="HexMaster.FloodRush.Game.Pages.WelcomePage"
             Shell.NavBarIsVisible="False">

    <!-- Root grid: background image + overlay + content stacked -->
    <Grid>
        <!-- Background illustration -->
        <Image Source="main_screen_background.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"/>

        <!-- Dark overlay — stronger on the right to keep buttons readable -->
        <BoxView HorizontalOptions="Fill" VerticalOptions="Fill">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#CC0d1b2a" Offset="0"/>
                    <GradientStop Color="#880d1b2a" Offset="0.45"/>
                    <GradientStop Color="#EE0d1b2a" Offset="1"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Page content — two columns -->
        <Grid ColumnDefinitions="*,Auto" Padding="40,24">

            <!-- Left: game title component -->
            <welcome:GameTitleView Grid.Column="0"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

            <!-- Right: main menu buttons component -->
            <welcome:MainMenuView Grid.Column="1"
                                  BindingContext="{Binding}"
                                  VerticalOptions="Center"
                                  HorizontalOptions="End"
                                  WidthRequest="260"/>
        </Grid>

        <Grid IsVisible="{Binding IsQuitConfirmationVisible}">
            <BoxView Color="{StaticResource AppBackground}"
                     Opacity="0.82"/>

            <Border Style="{StaticResource GameCardStyle}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumWidthRequest="520">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="16">
                    <VerticalStackLayout Grid.Row="0"
                                         Spacing="8">
                        <Label Text="Quit FloodRush?"
                               Style="{StaticResource PageTitleStyle}"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Your current session will close and you'll return to the operating system."
                               Style="{StaticResource BodyTextStyle}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <CheckBox IsChecked="{Binding DoNotShowQuitDialogAgain}"
                                  Color="{StaticResource BrandAmber}"
                                  VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Not show this dialog again"
                               Style="{StaticResource BodyTextStyle}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Text="Cancel"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelQuitCommand}"/>
                        <Button Grid.Column="1"
                                Text="Quit"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding ConfirmQuitCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>

