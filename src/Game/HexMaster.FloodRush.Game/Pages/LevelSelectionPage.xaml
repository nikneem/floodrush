<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HexMaster.FloodRush.Game.ViewModels"
             x:Class="HexMaster.FloodRush.Game.Pages.LevelSelectionPage"
             Shell.NavBarIsVisible="False">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0d1b2a" Offset="0"/>
            <GradientStop Color="#102035" Offset="1"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*" Padding="24,16">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,16">
            <Button Grid.Column="0"
                    Text="← Back"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding BackCommand}"
                    Padding="16,10"/>
            <Label Grid.Column="1"
                   Text="Select a Level"
                   Style="{StaticResource SectionHeadingStyle}"
                   VerticalOptions="Center"
                   Margin="16,0"/>
        </Grid>

        <!-- Level list -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Levels}"
                        SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:LevelListItem">
                    <Border Style="{StaticResource GameCardStyle}">
                        <Grid RowDefinitions="*,Auto,Auto" RowSpacing="8">
                            <Label Grid.Row="0"
                                   Text="{Binding DisplayName}"
                                   Style="{StaticResource SectionHeadingStyle}"
                                   FontSize="16"
                                   HorizontalOptions="Start"/>
                            <Label Grid.Row="1"
                                   Text="{Binding Difficulty}"
                                   Style="{StaticResource MutedTextStyle}"/>
                            <Button Grid.Row="2"
                                    Text="Play"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,8"
                                    FontSize="13"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectLevelCommand}"
                                    CommandParameter="{Binding .}"
                                    HorizontalOptions="Fill"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
